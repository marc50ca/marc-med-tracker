# Marc Med Tracker Configuration
# Copy this to your configuration.yaml and adjust dates/values as needed

marc_med_tracker:
  medications:
    # ========================================
    # DIABETES MANAGEMENT
    # ========================================
    
    - name: "Jardiance"
      prescribing_doctor: "Dr. Smith"
      refills_left: 3
      last_refilled: "2025-02-20"
      strength: "10mg"
      doses_per_day: 1
      pills_per_dose: 1
      initial_stock: 90
      notes: "Take in the morning with breakfast"
    
    - name: "Metformin"
      prescribing_doctor: "Dr. Smith"
      refills_left: 5
      last_refilled: "2025-02-15"
      strength: "500mg"
      doses_per_day: 2          # Morning and evening
      pills_per_dose: 1
      initial_stock: 180          # 90-day supply x 2 per day
      notes: "Take with meals - morning and evening"
    
    # ========================================
    # DIGESTIVE HEALTH
    # ========================================
    
    - name: "Pantoloc"
      prescribing_doctor: "Dr. Johnson"
      refills_left: 4
      last_refilled: "2025-02-18"
      strength: "40mg"
      doses_per_day: 1
      pills_per_dose: 1
      initial_stock: 90
      notes: "Take 30 minutes before breakfast"
    
    # ========================================
    # CHOLESTEROL MANAGEMENT
    # ========================================
    
    - name: "Rosuvastatin"
      prescribing_doctor: "Dr. Smith"
      refills_left: 6
      last_refilled: "2025-02-10"
      strength: "20mg"
      doses_per_day: 1
      pills_per_dose: 1
      initial_stock: 90
      notes: "Take at bedtime"
    
    # ========================================
    # BLOOD PRESSURE & HEART HEALTH
    # ========================================
    
    - name: "Candesartan"
      prescribing_doctor: "Dr. Wilson"
      refills_left: 5
      last_refilled: "2025-02-12"
      strength: "16mg"
      doses_per_day: 1
      pills_per_dose: 1
      initial_stock: 90
      notes: "Take in the morning"
    
    - name: "Bisoprolol"
      prescribing_doctor: "Dr. Wilson"
      refills_left: 4
      last_refilled: "2025-02-14"
      strength: "5mg"
      doses_per_day: 1
      pills_per_dose: 1
      initial_stock: 90
      notes: "Take in the morning with food"
    
    - name: "Spironolactone"
      prescribing_doctor: "Dr. Wilson"
      refills_left: 3
      last_refilled: "2025-02-16"
      strength: "25mg"
      doses_per_day: 1
      pills_per_dose: 1
      initial_stock: 90
      notes: "Monitor potassium levels regularly"
    
    # ========================================
    # BLOOD THINNER (Critical - Don't Miss!)
    # ========================================
    
    - name: "Edoxaban"
      prescribing_doctor: "Dr. Wilson"
      refills_left: 2
      last_refilled: "2025-02-22"
      strength: "60mg"
      doses_per_day: 1
      pills_per_dose: 1
      initial_stock: 90
      notes: "CRITICAL: Take at same time daily - do not miss doses!"
    
    # ========================================
    # RESPIRATORY (Inhaler)
    # ========================================
    
    - name: "Zenhale Inhaler"
      prescribing_doctor: "Dr. Brown"
      refills_left: 2
      last_refilled: "2025-01-15"
      strength: "100/6 mcg"
      doses_per_day: 2            # Morning and evening
      pills_per_dose: 2            # 2 puffs per dose
      initial_stock: 120           # 60 doses x 2 puffs = 120 puffs total
      notes: "2 puffs twice daily - rinse mouth after use"

# ========================================
# IMPORTANT NOTES
# ========================================
# 
# After adding this configuration:
# 1. Update the 'last_refilled' dates to match when you actually got each medication
# 2. Adjust 'refills_left' to your current refill count
# 3. Change doctor names to your actual doctors
# 4. Restart Home Assistant
# 5. Check Developer Tools → States to verify sensors were created
#
# You should see 9 sensors created:
# - sensor.marc_med_jardiance
# - sensor.marc_med_metformin
# - sensor.marc_med_pantoloc
# - sensor.marc_med_rosuvastatin
# - sensor.marc_med_candesartan
# - sensor.marc_med_bisoprolol
# - sensor.marc_med_spironolactone
# - sensor.marc_med_edoxaban
# - sensor.marc_med_zenhale_inhaler
